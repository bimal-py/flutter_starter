# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env` (it's gitignored).
#
# WARNING: anything in `.env` ships inside the compiled app binary and can be
# extracted from an IPA/APK. Use this for OAuth client IDs, API base URLs, and
# obfuscation-tier keys — NOT for real secrets. Real secrets must live behind
# your backend.

# --- Firebase (set to true to enable Crashlytics/Analytics in release) ---
FIREBASE_ENABLED=false

# --- Networking (when you add an API layer) ---
API_BASE_URL=

# --- Backend auth keys (DEV vs PROD picked automatically by build mode) ---
DEV_AUTH_KEY=
PROD_AUTH_KEY=

# --- Auth provider keys (when you add auth) ---
GOOGLE_SERVER_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_REDIRECT_URL=
